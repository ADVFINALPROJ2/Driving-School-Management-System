# Copy to backend/.env (git-ignored) and adjust as needed.
# These are consumed by config/database.yml and docker-compose.yml.

# --- Database connection ---
# For local-native Rails, leave DATABASE_HOST as localhost.
# docker-compose.yml overrides DATABASE_HOST=postgres for the rails-api container.
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=backend_development
DATABASE_TEST_NAME=backend_test

# Host port the Postgres container publishes. Change if 5432 is already taken
# on your machine (e.g. another project's Postgres). Internal port stays 5432.
POSTGRES_PUBLISHED_PORT=5432

# --- Auth ---
# Secret used to sign JWTs (devise-jwt). Falls back to secret_key_base if unset,
# which is fine for local dev; set a dedicated value in production.
DEVISE_JWT_SECRET_KEY=

# --- Background jobs (Solid Queue) ---
# Jobs run through Solid Queue in development, backed by a separate
# <DATABASE_NAME>_queue database (created by `bin/rails db:prepare`).
# When true, the worker runs inside the Puma web process (no separate container).
# Set false and run `bin/jobs` in its own process if you prefer.
SOLID_QUEUE_IN_PUMA=true

# --- App ---
# ADMIN_EMAIL is used by Meklit::BatchingService for submission notifications.
ADMIN_EMAIL=admin@drivingschool.et
