# Copy to .env.prod on the VPS (git-ignored) and fill in. Consumed by
# docker-compose.prod.yml. Do NOT commit the filled-in file.

# Rails master key — paste the contents of backend/config/master.key
RAILS_MASTER_KEY=

# Choose a strong Postgres password for the `backend` role
BACKEND_DATABASE_PASSWORD=

# Public hostnames (must match your DNS + nginx vhosts)
APP_HOST=api.dtmf.studio
ALLOWED_ORIGINS=https://app.dtmf.studio

# Baked into the frontend bundle at build time
API_URL=https://api.dtmf.studio
