# Copy to Client/.env.local (git-ignored) and adjust as needed.
# These are consumed by next.config.ts and src/lib/api.ts.

# URL of the Rails API backend (used by all fetch calls in api.ts).
NEXT_PUBLIC_API_URL=http://localhost:3001

# Default batch ID used when creating new students via the enrollment wizard.
NEXT_PUBLIC_DEFAULT_BATCH_ID=1

# Set to "true" to use mock users instead of a real backend API for authentication.
# Mock users are defined in src/lib/mock-users.ts.
# NEXT_PUBLIC_USE_MOCK_AUTH=true
